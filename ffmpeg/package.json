{
  "name": "@patchwork/ffmpeg",
  "version": "0.0.1",
  "description": "Audio, video, and image conversion for Patchwork via ffmpeg.wasm.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "push": "pnpm build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [
    "ffmpeg",
    "patchwork"
  ],
  "author": "Ink & Switch",
  "dependencies": {
    "@automerge/automerge": "^3.2.1",
    "@automerge/automerge-repo": "^2.5.0",
    "@automerge/automerge-repo-solid-primitives": "^2.5.1",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@inkandswitch/patchwork-elements": "^0.0.5",
    "@inkandswitch/patchwork-filesystem": "^0.0.3",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.0.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vite-plugin-solid": "^2.10.0"
  }
}
