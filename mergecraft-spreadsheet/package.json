{
  "name": "@patchwork/mergecraft-spreadsheet",
  "version": "0.0.2",
  "description": "Editable spreadsheet view of a Mergecraft world: one row per block, live two-way bound to the doc",
  "type": "module",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc && vite build",
    "push": "pnpm build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [],
  "author": "Ink & Switch",
  "dependencies": {
    "@automerge/automerge-repo": "2.6.0-subduction.37",
    "@inkandswitch/patchwork-plugins": "^0.0.2",
    "@inkandswitch/patchwork-providers": "^0.3.0",
    "bireactive": "^0.3.3"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.0.3",
    "@types/node": "^20.19.39",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}