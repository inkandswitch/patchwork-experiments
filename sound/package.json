{
  "name": "@patchwork/recording",
  "version": "0.0.1",
  "description": "Audio recording tool for Patchwork",
  "type": "module",
  "main": "./dist/recording.js",
  "exports": {
    ".": {
      "import": "./dist/recording.js",
      "source": "./src/recording.js"
    }
  },
  "scripts": {
    "build": "node esbuild/build.js",
    "dev": "node esbuild/watch.js",
    "pushwatch": "pnpm dev pushwork",
    "push": "pnpm build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [],
  "author": "Ink & Switch",
  "dependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.0.4",
    "@inkandswitch/patchwork-providers": "^0.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.23.1"
  }
}
