{
  "name": "@patchwork/add-module-to-settings",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "CLI: manage module-settings docs (add / remove / create) over Subduction sync",
  "scripts": {
    "add-module": "tsx add-module-to-settings.ts",
    "register": "patchwork-register-module add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\"",
    "unregister": "patchwork-register-module remove \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\"",
    "create-module-settings": "patchwork-register-module create"
  },
  "dependencies": {
    "@automerge/automerge-repo": "2.6.0-subduction.14",
    "@automerge/automerge-repo-storage-nodefs": "2.6.0-subduction.14",
    "@automerge/automerge-subduction": "0.7.0",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
