{
  "name": "@patchwork/lighterpack",
  "version": "0.0.1",
  "description": "A LighterPack clone for backpacking gear management",
  "type": "module",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc && vite build",
    "sync": "pnpm build && npx pushwork sync",
    "push": "pushwork sync",
    "watch": "nodemon --watch src -e js,tsx,ts,tsx,css,json --exec 'pnpm build && pnpm push'",
    "register": "patchwork-register-module \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [],
  "author": "Ink & Switch",
  "dependencies": {
    "@automerge/automerge": "3.2.1",
    "@automerge/automerge-repo": "2.5.0",
    "@automerge/automerge-repo-react-hooks": "2.5.0",
    "@inkandswitch/patchwork-plugins": "^0.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.0.3",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "nodemon": "^3.1.10",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1"
  }
}
