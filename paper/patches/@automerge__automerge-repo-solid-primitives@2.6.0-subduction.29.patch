 function applyDelPatch(doc, path, patch) {
 	let { obj: parent, prop, parentPath } = pathElemAt(path, -1);
+	// PATCHED: the fragments prerelease dropped map-key deletes, so a `del`
+	// patch with a string prop (deleting an object property) threw
+	// "index is not a number for patch". Restore the mainline behavior.
+	if (typeof prop === "string" && typeof parent === "object" && parent !== null && !Array.isArray(parent)) {
+		delete parent[prop];
+		return;
+	}
 	if (!(typeof prop === "number")) throw new RangeError(`index is not a number for patch`);
 	if (Array.isArray(parent)) parent.splice(prop, patch.length || 1);
