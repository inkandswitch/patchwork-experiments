{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "paths": {
      "@automerge/automerge-repo-solid-primitives": [
        "./src/automerge-repo-solid-primitives/index.ts"
      ]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
