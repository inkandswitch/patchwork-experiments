{
  "name": "@patchwork/paper",
  "version": "0.0.1",
  "description": "paper tool",
  "type": "module",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "sync": "pnpm build && pushwork sync",
    "format": "pnpm exec prettier --write \"src/**/*.{ts,tsx,css}\"",
    "register": "patchwork-register-module \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [],
  "author": "Ink & Switch",
  "dependencies": {
    "@automerge/automerge": "3.2.1",
    "@automerge/automerge-repo": "2.5.2-alpha.0",
    "@automerge/automerge-repo-solid-primitives": "2.5.2-alpha.0",
    "@inkandswitch/annotations": "0.1.4",
    "@inkandswitch/annotations-context": "0.1.4",
    "@inkandswitch/annotations-diff": "0.1.4",
    "@inkandswitch/patchwork-elements": "^0.0.5",
    "@inkandswitch/patchwork-filesystem": "^0.0.3",
    "@inkandswitch/patchwork-plugins": "^0.0.2",
    "@patchwork/llm": "link:../llm",
    "lucide-solid": "^0.577.0",
    "modern-screenshot": "^4.6.8",
    "perfect-freehand": "^1.2.3",
    "solid-js": "^1.9.11",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "overrides": {
      "@automerge/automerge-repo": "2.5.2"
    }
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-solid": "^2.11.11"
  }
}
