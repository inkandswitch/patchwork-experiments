{
  "name": "@patchwork/paper",
  "version": "0.0.5",
  "description": "paper: a 2d canvas that stacks per-layer documents with css z-ordering",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch & npx --yes http-server . -p 5173 --cors -c-1",
    "prettier": "prettier --write .",
    "push": "yarn build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "author": "paul",
  "dependencies": {
    "@automerge/automerge-repo": "2.6.0-subduction.29",
    "@automerge/automerge-repo-solid-primitives": "2.6.0-subduction.29",
    "@inkandswitch/patchwork-elements": "^0.2.0",
    "@inkandswitch/patchwork-plugins": "^0.0.11",
    "maplibre-gl": "^5.24.0",
    "perfect-freehand": "^1.2.3",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.2.5",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-solid": "^2.10.0"
  }
}
