{
  "name": "@patchwork/physical-frame",
  "version": "0.0.1",
  "description": "Physical frame: camera/projector alignment + calibration + an embedded patchwork-view, with pluggable, registry-discovered physical-layer readers fed via providers (demand-driven)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "push": "vite build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [],
  "author": "Ink & Switch",
  "dependencies": {
    "@automerge/automerge": "3.3.0-fragments.1",
    "@automerge/automerge-repo": "^2.6.0-subduction.26",
    "@automerge/automerge-repo-solid-primitives": "^2.6.0-subduction.26",
    "@inkandswitch/patchwork-elements": "^0.2.0",
    "@inkandswitch/patchwork-filesystem": "^0.0.8",
    "@inkandswitch/patchwork-plugins": "^0.0.11",
    "@inkandswitch/patchwork-providers": "^0.2.1",
    "@kobalte/core": "^0.13.11",
    "lucide-solid": "^0.577.0",
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.2.4",
    "typescript": "^5.8.3",
    "vite": "^7.1.9",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-solid": "^2.11.10"
  }
}
