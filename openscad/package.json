    "@codemirror/view": "^6.40.0",
    "@inkandswitch/patchwork-elements": "^0.0.5",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.0",
    "solid-js": "^1.9.11",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.0.4",
