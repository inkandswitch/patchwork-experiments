{
	"compilerOptions": {
		"target": "ESNEXT",
		"module": "ESNEXT",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"lib": ["ESNEXT", "DOM", "DOM.Iterable"],
		"allowJs": true,
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["src"]
}
