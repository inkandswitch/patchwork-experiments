    "@pixiv/three-vrm": "^3.5.2",
    "@undecaf/zbar-wasm": "^0.11.0",
    "qrcode": "^1.5.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.0.9",
    "@types/qrcode": "^1.5.5",
    "@types/three": "^0.184.1",
    "esbuild": "^0.23.1"
  }
}
