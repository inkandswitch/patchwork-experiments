#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# `and` — the RLM widget-model toolchain CLI (mlx path).
#
#   ./and train  <name> [-s suffix] [--base <hf-id>] [--epochs N] [--iters N] [...]
#                (iters auto-computed from epochs × train_examples / batch)
#   ./and prompt <name> [-s suffix] "what is a dog exactly?"
#   ./and fuse   <name> [-s suffix]
#   ./and onnx   <name> [-s suffix] [--no-quantize]
#   ./and mlc    <name> [-s suffix] [--quant q4f16_1] [--conv LM]   # WebLLM/MLC
#   ./and upload <name> [-s suffix] <hf-repo>
#   ./and data                       # (re)build the shared dataset
#
# Per-model layout (one dir per model, shared dataset in ./data):
#   models/<name>[-<suffix>]/
#     base            # the HF base id this was trained from
#     checkpoints/    # mlx LoRA adapter (--adapter-path)
#     merged/         # fused standalone HF model (mlx_lm.fuse)
#     onnx/           # transformers.js layout: config + tokenizer here,
#                     #   weights under onnx/onnx/model.onnx (+ model_quantized.onnx)
#     mlc/            # WebLLM/MLC weights + config + compiled WebGPU .wasm lib
#
# Base id is resolved from --base, then models/<dir>/base, then the built-in
# registry below. `train` records it so later steps need no --base.
# ---------------------------------------------------------------------------
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$HERE"

# Tools: python/optimum from the local venv (has onnxruntime + optimum);
# mlx_lm.* and huggingface-cli from PATH.
PY="$HERE/.venv/bin/python";        [ -x "$PY" ]      || PY="python3"
OPTIMUM="$HERE/.venv/bin/optimum-cli"; [ -x "$OPTIMUM" ] || OPTIMUM="optimum-cli"
HF="$HERE/.venv/bin/huggingface-cli"; [ -x "$HF" ]     || HF="huggingface-cli"

# Built-in name -> base HF id registry. Add yours here, or pass --base once.
registry_base() {
  case "$1" in
    gemma3-270m|gemma-3-270m)            echo "google/gemma-3-270m" ;;
    qwen2.5-coder-1.5b|qwen-coder-1.5b)  echo "Qwen/Qwen2.5-Coder-1.5B" ;;
    qwen2.5-coder-0.5b|qwen-coder-0.5b)  echo "Qwen/Qwen2.5-Coder-0.5B" ;;
    *) echo "" ;;
  esac
}

# Per-model training defaults: "batch num-layers lr epochs" (lr "-" = mlx
# default). iters are COMPUTED from epochs × train_examples / batch, so the run
# auto-scales as the dataset grows (a fixed iters count silently under-trains a
# bigger set). Tiny models (gemma-270m) want more epochs + a higher LR to learn
# the format; a 1.5B LoRA wants ~3 epochs (watch val loss for overfit).
registry_defaults() {
  case "$1" in
    gemma3-270m|gemma-3-270m)            echo "4 16 1e-4 8" ;;
    qwen2.5-coder-1.5b|qwen-coder-1.5b)  echo "4 16 - 3" ;;
    qwen2.5-coder-0.5b|qwen-coder-0.5b)  echo "4 16 - 4" ;;
    *) echo "2 16 - 3" ;;
  esac
}

die() { echo "error: $*" >&2; exit 1; }

usage() {
  sed -n '3,/^# ---/p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# ---- parse ----------------------------------------------------------------
cmd="${1:-help}"; shift || true

NAME="" SUFFIX="" BASE="" REQ="" REPO=""
ITERS="" BATCH="" LAYERS="" LR="" EPOCHS="" TOKENS="400" DTYPE="q8"
QUANT="q4f16_1" CONV="LM" LIB="" CTX=""
MERGED=0 NOQUANT=0 NODATA=0
EXTRA=()
# mlc_llm lives in the from-source conda 'mlc' env (TVM built locally).
MLC_PY="${MLC_PY:-/opt/homebrew/Caskroom/miniforge/base/envs/mlc/bin/python}"
# mlx_lm lives in its pipx venv; we call its python directly for generation.
MLX_PY="${MLX_PY:-/Users/chee/.local/pipx/venvs/mlx-lm/bin/python}"

while [ $# -gt 0 ]; do
  case "$1" in
    -s|--suffix)         SUFFIX="$2"; shift 2 ;;
    --base)              BASE="$2";   shift 2 ;;
    --iters)             ITERS="$2";  shift 2 ;;
    --batch-size|--batch) BATCH="$2"; shift 2 ;;
    --num-layers|--layers) LAYERS="$2"; shift 2 ;;
    --lr|--learning-rate) LR="$2";    shift 2 ;;
    --epochs)            EPOCHS="$2"; shift 2 ;;
    --tokens|--max-tokens) TOKENS="$2"; shift 2 ;;
    --dtype)             DTYPE="$2";  shift 2 ;;
    --quant)             QUANT="$2";  shift 2 ;;
    --conv|--conv-template) CONV="$2"; shift 2 ;;
    --lib)               LIB="$2";    shift 2 ;;
    --ctx|--context)     CTX="$2";    shift 2 ;;
    --merged)            MERGED=1;    shift ;;
    --no-quantize)       NOQUANT=1;   shift ;;
    --no-data)           NODATA=1;    shift ;;
    --)                  shift; EXTRA+=("$@"); break ;;
    -*)                  die "unknown flag: $1" ;;
    *)
      if   [ -z "$NAME" ]; then NAME="$1"
      elif [ -z "$REQ" ];  then REQ="$1"; REPO="$1"
      else EXTRA+=("$1"); fi
      shift ;;
  esac
done

MODEL_DIR="models/${NAME}${SUFFIX:+-$SUFFIX}"
CKPT="$MODEL_DIR/checkpoints"
MERGED_DIR="$MODEL_DIR/merged"
ONNX_DIR="$MODEL_DIR/onnx"
MLC_DIR="$MODEL_DIR/mlc"

resolve_base() {
  if   [ -n "$BASE" ];               then echo "$BASE"
  elif [ -f "$MODEL_DIR/base" ];     then cat "$MODEL_DIR/base"
  else
    local b; b="$(registry_base "$NAME")"
    [ -n "$b" ] || die "unknown base for '$NAME' — pass --base <hf-id> (it gets remembered)"
    echo "$b"
  fi
}

build_data() {
  if compgen -G "exports/*.jsonl" >/dev/null 2>&1; then
    "$PY" prepare.py exports/*.jsonl
  else
    "$PY" prepare.py
  fi
}

# ---- commands -------------------------------------------------------------
case "$cmd" in
  help|-h|--help) usage 0 ;;

  data) build_data ;;

  train)
    [ -n "$NAME" ] || die "usage: ./and train <name> [-s suffix] [--base <hf-id>]"
    mkdir -p "$MODEL_DIR"
    base="$(resolve_base)"; echo "$base" > "$MODEL_DIR/base"
    # Fill unset hyperparameters from the per-model defaults: "batch layers lr epochs".
    read -r d_batch d_layers d_lr d_epochs <<<"$(registry_defaults "$NAME")"
    [ "$d_lr" = "-" ] && d_lr=""
    BATCH="${BATCH:-$d_batch}"; LAYERS="${LAYERS:-$d_layers}"
    LR="${LR:-$d_lr}"; EPOCHS="${EPOCHS:-$d_epochs}"
    [ "$NODATA" = 1 ] || build_data
    # iters auto-scale to the dataset: epochs × train_examples / batch (unless
    # --iters is given explicitly). A fixed iters count silently under-trains a
    # bigger set — e.g. 800 over 900 examples is < 1 epoch.
    TRAIN_N=$(wc -l < ./data/train.jsonl | tr -d ' ')
    if [ -z "$ITERS" ]; then
      ITERS=$(( (EPOCHS * TRAIN_N + BATCH - 1) / BATCH ))
    fi
    echo "▸ training $NAME from $base -> $CKPT"
    echo "  ${EPOCHS} epochs over ${TRAIN_N} examples → iters=$ITERS  (batch=$BATCH, layers=$LAYERS, lr=${LR:-<mlx default>})"
    mlx_lm.lora --model "$base" --train --data ./data \
      --iters "$ITERS" --batch-size "$BATCH" --num-layers "$LAYERS" \
      ${LR:+--learning-rate "$LR"} \
      --adapter-path "$CKPT" ${EXTRA[@]+"${EXTRA[@]}"}
    echo "✓ adapter at $CKPT — try: ./and prompt $NAME ${SUFFIX:+-s $SUFFIX} \"what is a dog?\""
    ;;

  prompt)
    [ -n "$NAME" ] && [ -n "$REQ" ] || die "usage: ./and prompt <name> [-s suffix] \"<request>\""
    base="$(resolve_base)"
    # Pipe testprompt.py straight in — the trailing "\n\n" matters (the model
    # was trained on it) and $(...) would strip it. Use the mlx_lm API via
    # mlxgen.py; the mlx_lm.generate CLI mangles this long prompt to 0 tokens.
    if [ "$MERGED" = 1 ]; then
      [ -d "$MERGED_DIR" ] || die "no merged model at $MERGED_DIR — run: ./and fuse $NAME"
      "$PY" testprompt.py "$REQ" | "$MLX_PY" mlxgen.py "$MERGED_DIR" - "$TOKENS"
    elif [ -d "$CKPT" ]; then
      "$PY" testprompt.py "$REQ" | "$MLX_PY" mlxgen.py "$base" "$CKPT" "$TOKENS"
    else
      echo "(no adapter at $CKPT — prompting the raw base $base)" >&2
      "$PY" testprompt.py "$REQ" | "$MLX_PY" mlxgen.py "$base" - "$TOKENS"
    fi
    ;;

  fuse)
    [ -n "$NAME" ] || die "usage: ./and fuse <name> [-s suffix]"
    [ -d "$CKPT" ] || die "no adapter at $CKPT — run: ./and train $NAME"
    base="$(resolve_base)"
    echo "▸ fusing $base + $CKPT -> $MERGED_DIR"
    mlx_lm.fuse --model "$base" --adapter-path "$CKPT" --save-path "$MERGED_DIR"
    echo "✓ merged model at $MERGED_DIR"
    ;;

  onnx)
    [ -n "$NAME" ] || die "usage: ./and onnx <name> [-s suffix] [--no-quantize]"
    [ -d "$MERGED_DIR" ] || die "no merged model at $MERGED_DIR — run: ./and fuse $NAME"
    echo "▸ exporting $MERGED_DIR -> $ONNX_DIR (transformers.js layout)"
    rm -rf "$ONNX_DIR"; mkdir -p "$ONNX_DIR"
    "$OPTIMUM" export onnx --model "$MERGED_DIR" --task text-generation-with-past "$ONNX_DIR"
    # transformers.js wants weights under an onnx/ subdir, config+tokenizer on top.
    mkdir -p "$ONNX_DIR/onnx"
    shopt -s nullglob
    for f in "$ONNX_DIR"/*.onnx "$ONNX_DIR"/*.onnx_data; do mv "$f" "$ONNX_DIR/onnx/"; done
    shopt -u nullglob
    echo "✓ fp32 at $ONNX_DIR/onnx/model.onnx  (dtype: fp32)"
    if [ "$NOQUANT" = 0 ]; then
      # Build q8 + q4 (+ q4f16 when the model's fp16 export is clean) and keep
      # only the variants that actually load. Prints the available dtypes.
      "$PY" mkonnx.py "$ONNX_DIR"
    fi
    echo "  upload with: ./and upload $NAME ${SUFFIX:+-s $SUFFIX} <you>/<repo>"
    ;;

  mlc)
    # Compile the merged model to MLC format for WebLLM (in-browser WebGPU).
    # Uses the from-source mlc_llm in the conda 'mlc' env. With --lib <url> it
    # reuses a prebuilt WebLLM model lib (convert weights only — no emscripten).
    [ -n "$NAME" ] || die "usage: ./and mlc <name> [-s suffix] [--quant q4f16_1] [--conv LM] [--lib <wasm-url>]"
    [ -d "$MERGED_DIR" ] || die "no merged model at $MERGED_DIR — run: ./and fuse $NAME"
    "$MLC_PY" -c "import mlc_llm" 2>/dev/null || die "mlc_llm not importable in $MLC_PY (set MLC_PY)"
    export PATH="/opt/homebrew/opt/llvm/bin:/opt/homebrew/opt/emscripten/bin:$PATH"
    echo "▸ MLC convert $MERGED_DIR -> $MLC_DIR  (quant=$QUANT conv=$CONV)"
    rm -rf "$MLC_DIR"; mkdir -p "$MLC_DIR"
    # Reusing a prebuilt _csNk_ lib? match its compiled context window.
    if [ -n "$LIB" ] && [ -z "$CTX" ]; then
      case "$LIB" in *cs1k*) CTX=1024 ;; *cs2k*) CTX=2048 ;; *cs4k*) CTX=4096 ;; esac
    fi
    "$MLC_PY" -m mlc_llm convert_weight "$MERGED_DIR" --quantization "$QUANT" -o "$MLC_DIR"
    GENC=(--quantization "$QUANT" --conv-template "$CONV" -o "$MLC_DIR")
    [ -n "$CTX" ] && GENC+=(--context-window-size "$CTX" --prefill-chunk-size "$CTX")
    "$MLC_PY" -m mlc_llm gen_config "$MERGED_DIR" ${GENC[@]+"${GENC[@]}"}
    mid="${NAME}${SUFFIX:+-$SUFFIX}-${QUANT}-MLC"
    if [ -n "$LIB" ]; then
      libref="$LIB"
      echo "✓ weights+config in $MLC_DIR ; reusing prebuilt lib: $LIB"
    else
      wasm="$MLC_DIR/${mid}-webgpu.wasm"
      "$MLC_PY" -m mlc_llm compile "$MLC_DIR/mlc-chat-config.json" --device webgpu -o "$wasm"
      libref="<host $wasm publicly and put its URL here>"
      echo "✓ weights+config in $MLC_DIR ; compiled lib: $wasm"
    fi
    echo ""
    echo "next:"
    echo "  1. upload weights:  huggingface-cli upload <you>/$mid $MLC_DIR ."
    echo "  2. in the tool, set the widget id to:  webllm:$mid"
    echo "     and add to localStorage 'glomper:webllm-models':"
    echo "     [{\"model_id\":\"$mid\",\"model\":\"https://huggingface.co/<you>/$mid\",\"model_lib\":\"$libref\"}]"
    ;;

  upload)
    [ -n "$NAME" ] && [ -n "$REPO" ] || die "usage: ./and upload <name> [-s suffix] <hf-repo>"
    [ -d "$ONNX_DIR" ] || die "no onnx export at $ONNX_DIR — run: ./and onnx $NAME"
    echo "▸ uploading $ONNX_DIR -> $REPO"
    "$HF" upload "$REPO" "$ONNX_DIR" .
    echo "✓ set the tool's Widget model to $REPO with dtype q8"
    ;;

  *) echo "unknown command: $cmd" >&2; usage 1 ;;
esac
