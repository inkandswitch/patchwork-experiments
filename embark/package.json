    "@inkandswitch/patchwork-providers": "^0.2.2",
    "maplibre-gl": "^5.24.0",
    "solid-automerge": "^1.1.0",
    "solid-js": "^1.9.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.2.5",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
