{
  "name": "bullets-tool",
  "version": "0.2.1",
  "description": "An infinitely nested bullet list tool for patchwork",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p tsconfig.test.json",
    "dev": "vite build --watch",
    "dev:standalone": "vite --config vite.standalone.config.ts",
    "build:standalone": "vite build --config vite.standalone.config.ts"
  },
  "dependencies": {
    "@automerge/automerge-repo": "2.6.0-subduction.34",
    "@automerge/automerge-repo-keyhive": "0.3.0-alpha.sub.6c",
    "@automerge/automerge-repo-network-websocket": "2.6.0-subduction.34",
    "@automerge/automerge-repo-solid-primitives": "2.6.0-subduction.34",
    "@automerge/automerge-repo-storage-indexeddb": "2.6.0-subduction.34",
    "@automerge/automerge-repo-storage-nodefs": "2.6.0-subduction.34",
    "@automerge/automerge-subduction": "0.16.0",
    "@jtfmumm/patchwork-standalone-frame": "0.7.0",
    "solid-js": "^1.9.9",
    "vite": "^6.0.3",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-solid": "^2.11.10",
    "vite-plugin-wasm": "^3.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@automerge/automerge": "3.3.0-fragments.1",
    "@inkandswitch/patchwork-plugins": "^0.0.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "@automerge/automerge": "3.3.0-fragments.1",
      "@automerge/automerge-repo": "2.6.0-subduction.34",
      "@automerge/automerge-repo-keyhive": "0.3.0-alpha.sub.6c",
      "@automerge/automerge-repo-network-websocket": "2.6.0-subduction.34",
      "@automerge/automerge-repo-storage-indexeddb": "2.6.0-subduction.34",
      "@automerge/automerge-subduction": "0.16.0"
    }
  }
}
